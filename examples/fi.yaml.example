# yaml-language-server: $schema=../fi.schema.json
# fi configuration example — copy to ~/.config/fi/fi.yaml and fill in your values.
# Run `fi init` to have fi write this file for you automatically.
#
# Top-level structure:
#   version  — config format version (currently always 1)
#   jira     — Jira connection settings
#   common   — branch naming conventions shared across all repos
#   repos    — list of repositories fi manages

version: 1

# ── Jira ──────────────────────────────────────────────────────────────────────
jira:
  # Base URL of your Jira instance (no trailing slash)
  # Type: string
  baseUrl: https://myorg.atlassian.net

  # Numeric board ID — visible in the URL when viewing your Jira board:
  # https://myorg.atlassian.net/jira/software/projects/PROJ/boards/123
  # Type: integer
  boardId: 123

  # Quick filter ID to scope which issues appear in `fi new`.
  # A "My work" or "In Progress" filter keeps the list short and focused.
  # Visible in the board URL when a filter is active: ...?quickFilter=456
  # Type: integer
  quickFilterId: 456

  # Optional extra JQL appended to every issue query.
  # Useful to further narrow results (e.g. to a specific project or sprint).
  # Type: string | omit to disable
  # jqlExtension: "assignee = currentUser() AND sprint in openSprints()"

  token:
    # Name of the environment variable that holds your base64-encoded Jira API token.
    # The value must be: base64("your@email.com:your_api_token")
    #
    # Generate it once:
    #   echo -n "you@company.com:your_jira_api_token" | base64
    #
    # Then export it from your shell config (e.g. ~/.config/fish/config.fish):
    #   set -gx JIRA_TOKEN "dXNlcjp0b2tlbg=="
    #
    # Type: string (env var name, not the token value itself)
    env: JIRA_TOKEN

# ── Common ────────────────────────────────────────────────────────────────────
common:
  # Branch type prefixes available when creating a branch with `fi new`.
  # The user is prompted to pick one; it becomes the first segment of the branch name.
  # Type: list of strings
  branchPrefixes:
    - feature
    - fix
    - chore
    - wip
    - hotfix

  # Which prefix is pre-selected at the prompt.
  # Type: string (must be one of branchPrefixes)
  defaultBranchPrefix: feature

  # Optional: override the branch name format.
  # Default (if omitted): "{branchPrefix}/{ticket.key}-{slug}"
  # Available variables: {branchPrefix}, {ticket.key}, {slug}
  # Type: string | omit to use default
  # branchFormat: "{branchPrefix}/{ticket.key}-{slug}"

# ── Repos ─────────────────────────────────────────────────────────────────────
# List of repositories fi manages. Two types are supported:
#   worktree — a bare git repo that uses `git worktree` (one checkout per branch)
#   standard — a regular git checkout (branch switching via `git checkout -b`)
repos:

  # ── Example 1: git worktree repo (bare repo) ──────────────────────────────
  - name: My API
    # Path to the bare repo root. Tilde (~) is expanded.
    # For a bare repo cloned with: git clone --bare <url> my-api.git
    # Type: string (path)
    root: ~/proj/my-api.git

    # "worktree" for bare repos using git worktrees.
    # "standard" for regular checkouts (see Example 2 below).
    # Type: "worktree" | "standard"
    type: worktree

    # The main integration branch (used as the base for new branches).
    # Type: string
    defaultBranch: master

    # New worktrees are created at: <root>/<featurePath>/<branch>
    # Type: string
    featurePath: work

    # Worktrees at <root>/<persistentPath>/ are excluded from `fi cull` and `fi open`.
    # Type: string | omit to disable
    persistentPath: persistent

    # Branch names that are never offered in `fi cull` or `fi open`.
    # Type: list of strings | omit to disable
    persistentBranches:
      - master
      - develop

    # Target branches offered when running `fi pr` (all are pre-selected).
    # Type: list of strings
    prToBranches:
      - master
      - develop

    # Controls PR title and body generated by `fi pr`.
    # Omit this section to skip PR creation for this repo.
    prTemplate:
      # Optional fields to prompt for before rendering the PR.
      # Each key becomes available as {ask.<name>} in the title/body templates.
      # Type: map of field-name → field-type
      ask:
        description:
          # "editor" opens $EDITOR so you can write multi-line text.
          # Other types: "text" (single line), "boolean" (y/n prompt)
          type: editor
          # optional: true means pressing Esc skips this field (value becomes "")
          optional: true

      # PR title template.
      # Syntax:
      #   {variable}                — plain substitution
      #   {variable: 'fmt $1'}      — conditional: only rendered if variable is non-empty;
      #                               $1 is replaced with the variable value
      # Available variables:
      #   {branch.prettyTitle}  — branch slug converted to Title Case
      #   {ticket.key}          — Jira ticket key, e.g. PROJ-1234
      #   {pr.targetPrefix}     — target branch name, or "" when targeting defaultBranch
      #   {ask.<name>}          — value collected from an ask field above
      title: "{pr.targetPrefix: '[$1]: '}{branch.prettyTitle}"
      # Examples:
      #   targeting master  → "Fix Wy Claim Report"
      #   targeting staging → "[staging]: Fix Wy Claim Report"

      # PR body template. Same variable syntax as title.
      body: |
        ### Ticket: {ticket.key}
        {ask.description: '\n### Description:\n$1'}

    # Custom scripts run after creating or opening a worktree.
    # The script is written to a temp file and executed as: <runner> <tempfile>
    # The special command name "open" is invoked automatically by `fi open`.
    # Type: list | omit to disable
    commands:
      - command: open
        # Shell used to execute the script.
        # Type: string (binary name or full path)
        runner: fish
        # Optional prompts collected before the script runs.
        # Available in env vars via template syntax.
        ask:
          shouldInit: boolean
        # Environment variables passed to the script.
        # Template variables available: {branch.path}, {ask.<name>}
        env:
          BRANCH_PATH: "{branch.path}"
          SHOULD_INIT: "{ask.shouldInit}"
        # The script body (written to a temp file, then executed as `runner <tempfile>`).
        run: |
          echo "Opening $BRANCH_PATH"
          # Example: open editor + a side pane with WezTerm
          # set -l PANE_ID (wezterm cli spawn --cwd "$BRANCH_PATH")
          # wezterm cli send-text "nvim\n" --pane-id $PANE_ID

  # ── Example 2: standard (non-worktree) repo ───────────────────────────────
  - name: My Config
    # For a regular repo cloned with: git clone <url> my-config
    root: ~/proj/my-config
    type: standard
    defaultBranch: main

    prToBranches:
      - main
      - staging

    prTemplate:
      ask:
        description:
          type: editor
          optional: true
      title: "{pr.targetPrefix: '[$1]: '}{branch.prettyTitle}"
      body: |
        ### Ticket: {ticket.key}
        {ask.description: '\n### Description:\n$1'}
